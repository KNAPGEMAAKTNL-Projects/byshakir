---
// Country Estate, Antwerpen — /projects/country-estate-antwerpen/
// Primary keyword: country estate interior design Belgium
// Content: CONTENT/projects/country-estate-antwerpen.md
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaSection from '../../../components/CtaSection.astro';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import coverImg from '../../../assets/media/projects/country-estate-antwerpen/cover.webp';
import img01 from '../../../assets/media/projects/country-estate-antwerpen/01.webp';
import img02 from '../../../assets/media/projects/country-estate-antwerpen/02.webp';
import img03 from '../../../assets/media/projects/country-estate-antwerpen/03.webp';
import img04 from '../../../assets/media/projects/country-estate-antwerpen/04.webp';
import img05 from '../../../assets/media/projects/country-estate-antwerpen/05.webp';
type CoverMap = Record<string, { default: ImageMetadata }>;
const relatedCovers = import.meta.glob<{ default: ImageMetadata }>('../../../assets/media/projects/*/cover.webp', { eager: true }) as CoverMap;
const getRelatedCover = (slug: string) => relatedCovers[`../../../assets/media/projects/${slug}/cover.webp`].default;

const seoTitle = 'Country Estate, Antwerpen \u2014 Interior Design | By Shakir';
const seoDescription = 'Country estate interior in Belgium by By Shakir. Heritage architecture meets contemporary luxury living near Antwerpen, from concept to installation. View.';
const seoOgImage = coverImg.src;

const project = {
  title: 'Country Estate',
  location: 'Near Antwerpen, Belgium',
  overline: 'ANTWERPEN, BELGIUM',
  type: 'Complete residential interior',
  status: 'Completed',
};

const images = [
  { src: coverImg, alt: 'Country Estate Antwerpen — luxury residential interior by By Shakir', aspect: 'landscape' },
  { src: img01, alt: 'Reception room with high ceilings and contemporary furnishings in the Antwerpen country estate', aspect: 'landscape' },
  { src: img02, alt: 'Bespoke kitchen joinery with warm timber finish against original stone walls', aspect: 'landscape' },
  { src: img03, alt: 'Primary bedroom with linen bedding and muted colour palette', aspect: 'portrait' },
  { src: img04, alt: 'Library or study with built-in shelving and reading light', aspect: 'portrait' },
  { src: img05, alt: 'Garden room with views across the estate grounds', aspect: 'landscape' },
];

const relatedProjects = [
  { slug: 'villa-mansion-netherlands', title: 'Villa Mansion', location: 'Netherlands', tagline: 'Spacious Dutch residential interior' },
  { slug: 'duplex-penthouse-barcelona', title: 'Duplex Penthouse', location: 'Barcelona', tagline: 'Urban luxury across two levels' },
  { slug: 'beach-house-malaga', title: 'Beach House', location: 'Malaga', tagline: 'Mediterranean coastal living' },
];
---

<Layout title={seoTitle} description={seoDescription} ogImage={seoOgImage}>
  <Header currentPage="/projects/" />

  <main>
    <!-- ═══════════════════════════════════════════════════════════════
         PROJECT HERO — Dark, compact (40-65vh)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="project-hero">
      <svg class="grain" aria-hidden="true">
        <filter id="g-phero">
          <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="4" stitchTiles="stitch"/>
          <feColorMatrix type="saturate" values="0"/>
        </filter>
        <rect width="100%" height="100%" filter="url(#g-phero)"/>
      </svg>

      <div class="project-hero-content hero-content">
        <span class="overline overline-gold">PROJECT &middot; {project.overline}</span>
        <h1 class="project-hero-h1">{project.title}<span class="gold-comma">,</span> <span class="h1-location">Antwerpen</span></h1>
        <Breadcrumb items={[{ label: 'Projects', href: '/projects/' }, { label: project.title }]} />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         IMAGE GALLERY — Asymmetric 3-column grid
         ═══════════════════════════════════════════════════════════════ -->
    <section class="gallery">
      <div class="gallery-inner">
        <div class="gallery-grid">
          {images.map((img, i) => (
            <div class:list={['gallery-item', 'reveal', `d${Math.min(i + 1, 4)}`, { 'gallery-featured': i === 0 }]}>
              <Image
                src={img.src}
                alt={img.alt}
                widths={[600, 900, 1200]}
                sizes={i === 0 ? "(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 67vw" : "(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         PROJECT NARRATIVE — Left-aligned text
         ═══════════════════════════════════════════════════════════════ -->
    <section class="narrative">
      <div class="narrative-inner">
        <div class="narrative-meta reveal">
          <div class="meta-item">
            <span class="meta-label">Location</span>
            <span class="meta-value">{project.location}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Type</span>
            <span class="meta-value">{project.type}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Status</span>
            <span class="meta-value">{project.status}</span>
          </div>
        </div>

        <div class="narrative-body">
          <p class="narrative-lead reveal">A country estate near Antwerpen, designed by By Shakir as a complete residential commission. The project required a dialogue between the property's existing architectural character and a contemporary interior that the family could actually inhabit daily. Bespoke joinery, carefully sourced furnishings and a material palette that honours the building without imitating its era.</p>

          <h2 class="narrative-h2 gold-dot reveal">The Brief</h2>
          <p class="narrative-text reveal">The estate had architectural presence: high ceilings, deep window reveals, established proportions. The previous interior respected the period but had become static. The clients wanted something contemporary that would sit within the architecture rather than against it. Rooms that a family with children could use every day, not just admire.</p>

          <h2 class="narrative-h2 gold-dot reveal">The Approach</h2>
          <p class="narrative-text reveal">The key decision was restraint. Rather than stripping the architecture back to a blank canvas, we worked with its proportions. Ceiling heights dictated furniture scale. Window positions determined where seating would fall. The original flooring was retained where possible and complemented with natural stone in updated rooms.</p>
          <p class="narrative-text reveal">New joinery was designed to echo the proportions of existing built-in elements without copying the period detailing. Clean lines, warm timber, contemporary hardware. The effect is of a home that has evolved rather than been renovated.</p>
          <p class="narrative-text reveal">Colour was kept quiet. The palette draws from the surrounding landscape: greens and greys from the garden, warm creams from the local stone. Textiles add depth without introducing pattern for its own sake.</p>

          <h2 class="narrative-h2 gold-dot reveal">The Detail</h2>
          <p class="narrative-text reveal">The estate's scale required careful coordination between multiple trades: stonemasons, joiners, upholsterers and lighting specialists. Shakir managed each supplier directly and visited the site at key stages during the build. The <a href="/services/3d-design/" class="narrative-link">3D visualisation stage</a> proved especially valuable for testing contemporary furniture against the existing architectural backdrop.</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         RELATED PROJECTS
         ═══════════════════════════════════════════════════════════════ -->
    <section class="related">
      <div class="related-inner">
        <span class="overline overline-terracotta reveal">More Projects</span>
        <h2 class="related-h2 gold-dot reveal">Related Commissions</h2>

        <div class="related-grid">
          {relatedProjects.map((rp, i) => (
            <a href={`/projects/${rp.slug}/`} class:list={['related-card', 'reveal', `d${i + 1}`]}>
              <div class="related-card-img">
                <Image
                  src={getRelatedCover(rp.slug)}
                  alt={`${rp.title}, ${rp.location} \u2014 interior design by By Shakir`}
                  widths={[300, 500, 800]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="related-card-text">
                <span class="related-card-location">{rp.location}</span>
                <span class="related-card-title">{rp.title}</span>
                <span class="related-card-tagline">{rp.tagline}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CTA
         ═══════════════════════════════════════════════════════════════ -->
    <CtaSection
      heading="Considering a New Interior?"
      body="Whether you are planning a new build or reimagining an existing home \u2014 a conversation is where every project begins."
    />
  </main>

  <Footer />
</Layout>

<style>
  /* ── PROJECT HERO ───────────────────────────────────────── */
  .project-hero {
    position: relative;
    min-height: clamp(40vh, 50vh, 65vh);
    background: var(--color-dark);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .project-hero-content {
    position: relative;
    z-index: 2;
    padding: clamp(3rem, 6vh, 5rem) clamp(1.5rem, 5vw, 6rem);
    padding-top: 8rem;
  }
  .project-hero-h1 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 2.5rem + 4vw, 6.5rem);
    font-weight: 300;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-text-on-dark);
  }
  .gold-comma { color: var(--color-gold); }
  .h1-location {
    font-weight: 300;
    color: var(--color-text-muted-dark);
  }

  /* ── IMAGE GALLERY ──────────────────────────────────────── */
  .gallery {
    background: var(--color-bg);
    padding-block: clamp(3rem, 4vw + 1rem, 6rem);
  }
  .gallery-inner {
    padding-inline: clamp(1.5rem, 5vw, 5rem);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: clamp(220px, 24vw, 380px);
    gap: clamp(0.75rem, 1.2vw, 1.125rem);
  }
  .gallery-featured {
    grid-column: span 2;
    grid-row: span 2;
  }
  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .gallery-item:hover img {
    transform: scale(1.03);
  }

  /* ── NARRATIVE ──────────────────────────────────────────── */
  .narrative {
    background: var(--color-bg);
    padding-block: clamp(2rem, 3vw, 4rem) clamp(5rem, 6vw + 2rem, 9rem);
  }
  .narrative-inner {
    padding-inline: clamp(1.5rem, 5vw, 5rem);
  }
  .narrative-meta {
    display: flex;
    gap: clamp(2rem, 4vw, 4rem);
    padding-bottom: clamp(2rem, 3vw, 3.5rem);
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }
  .meta-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }
  .meta-value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.3;
  }
  .narrative-body {
    max-width: 65ch;
  }
  .narrative-lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.125rem);
    font-weight: 300;
    line-height: 1.72;
    color: var(--color-text);
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .narrative-h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: 1rem;
    margin-top: clamp(2rem, 3vw, 3rem);
  }
  .narrative-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.72;
    color: var(--color-text-muted);
    margin-bottom: 1em;
  }
  .narrative-link {
    color: var(--color-terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--color-terracotta);
    transition: opacity 0.3s;
  }
  .narrative-link:hover { opacity: 0.65; }

  /* ── RELATED PROJECTS ───────────────────────────────────── */
  .related {
    background: var(--color-surface);
    padding-block: clamp(5rem, 5vw + 2rem, 8rem);
  }
  .related-inner {
    padding-inline: clamp(1.5rem, 5vw, 5rem);
  }
  .related-h2 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }
  .related-card {
    display: block;
    text-decoration: none;
    border-radius: 2px;
    overflow: hidden;
  }
  .related-card-img {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .related-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .related-card:hover .related-card-img img {
    transform: scale(1.03);
  }
  .related-card-text {
    padding: clamp(1rem, 1.5vw, 1.5rem) 0;
  }
  .related-card-location {
    display: block;
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: 0.3rem;
  }
  .related-card-title {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.375rem;
  }
  .related-card-tagline {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery-featured {
      grid-column: span 2;
      grid-row: span 1;
      aspect-ratio: 16/9;
    }
  }

  @media (max-width: 768px) {
    .project-hero-h1 {
      font-size: clamp(2.25rem, 9vw, 4rem);
    }
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: clamp(240px, 65vw, 360px);
    }
    .gallery-featured {
      grid-column: 1;
      grid-row: span 1;
      aspect-ratio: auto;
    }
    .narrative-meta {
      flex-direction: column;
      gap: 1.25rem;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
