<script>
  // Delay hero video load until after LCP — prevents 4MB download from competing with poster image.
  // No { once: true }: listener persists across View Transitions so back-navigation works.
  document.addEventListener('astro:page-load', function () {
    var v = document.querySelector('.hero-video');
    if (v && v.dataset.src && !v.getAttribute('src')) {
      v.setAttribute('src', v.dataset.src);
      v.load();
      v.play().catch(function () {});
    }
  });
</script>
