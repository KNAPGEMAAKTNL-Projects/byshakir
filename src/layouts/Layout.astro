---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/effects.css';
import defaultOgImg from '../assets/media/hero-poster.webp';
import SchemaLocalBusiness from '../components/seo/SchemaLocalBusiness.astro';
import SchemaBreadcrumb from '../components/seo/SchemaBreadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description = 'By Shakir designs luxury interior design across the Netherlands, Dubai, Barcelona and Malaga. Complete homes from concept to installation. Begin a conversation.',
  ogImage = defaultOgImg.src,
  canonical,
  noindex = false,
  lang = 'en',
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://www.byshakir.com/';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteBase).href;
const ogImageURL = new URL(ogImage, siteBase).href;
const ogLocale = lang === 'nl' ? 'nl_NL' : 'en_GB';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Title & description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Robots -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="By Shakir" />

    <!-- Preload critical font: Cormorant Garamond 300 (hero heading) -->
    <link rel="preload" href="/fonts/cormorant-garamond-latin-300.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Structured data -->
    <SchemaLocalBusiness />
    <SchemaBreadcrumb />
    <slot name="head" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Page transitions (ssgoi / ViewTransitions API) -->
    <ClientRouter />
  </head>
  <body>
    <slot />

    <!-- No sticky mobile CTA bar — DESIGN.md §12: "Not appropriate here" (Archetype B, not A) -->

    <!-- Scroll reveals + GSAP lazy-load via IntersectionObserver -->
    <script>
      function initReveal() {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => io.observe(el));
      }

      // GSAP: load via dynamic import only when animated elements approach viewport
      let gsapLoaded = false;
      async function loadGSAP() {
        if (gsapLoaded) return;
        gsapLoaded = true;
        const { initGSAP } = await import('../scripts/gsap-effects');
        await initGSAP();
      }

      function scheduleGSAP() {
        const targets = document.querySelectorAll('.pcard, .hero-h1, .step');
        if (targets.length === 0) return;
        const io = new IntersectionObserver(
          (entries) => {
            if (entries.some((e) => e.isIntersecting)) {
              loadGSAP();
              io.disconnect();
            }
          },
          { rootMargin: '300px' }
        );
        targets.forEach((el) => io.observe(el));
      }

      initReveal();
      scheduleGSAP();

      document.addEventListener('astro:after-swap', () => {
        initReveal();
        gsapLoaded = false;
        scheduleGSAP();
      });
    </script>

    <!-- Noscript: ensure .reveal content is visible without JS -->
    <noscript>
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    </noscript>
  </body>
</html>
