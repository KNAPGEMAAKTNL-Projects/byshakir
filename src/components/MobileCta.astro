---
// MobileCta — Sticky bottom bar on mobile only
// Phone + primary CTA button
// Hidden on desktop (display: none above 768px)
interface Props {
  ctaText?: string;
  ctaHref?: string;
}
const {
  ctaText = 'Begin a Conversation',
  ctaHref = '/contact/',
} = Astro.props;
---

<div class="mobile-cta-bar">
  <a href="tel:+31344655473" class="mobile-cta-phone" aria-label="Call By Shakir">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M6.62 7.79c.94 1.86 2.73 3.65 4.59 4.59l1.53-1.53a.75.75 0 01.77-.18c.84.28 1.75.43 2.69.43.41 0 .75.34.75.75v2.65c0 .41-.34.75-.75.75C7.39 15.25 .75 8.61.75 .55A.75.75 0 011.5-.2h2.65c.41 0 .75.34.75.75 0 .94.15 1.85.43 2.69a.75.75 0 01-.18.77L3.62 5.54" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" transform="translate(1.25,1.25)"/>
    </svg>
    <span>Call</span>
  </a>
  <a href={ctaHref} class="mobile-cta-button">{ctaText}</a>
</div>

<style>
  .mobile-cta-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--color-dark);
    border-top: 1px solid rgba(201, 169, 98, 0.18);
    padding: 0.75rem clamp(1rem, 3vw, 1.5rem);
    gap: 0.75rem;
    align-items: center;
  }
  .mobile-cta-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-on-dark);
    text-decoration: none;
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
    padding: 0 0.75rem;
    border: 1px solid rgba(206, 196, 182, 0.25);
    border-radius: 2px;
    transition: border-color 0.3s;
    flex-shrink: 0;
  }
  .mobile-cta-phone:hover { border-color: var(--color-gold); }
  .mobile-cta-button {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    min-height: 44px;
    background: var(--color-gold);
    color: var(--color-dark);
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.7s var(--ease);
  }
  .mobile-cta-button:hover { background: var(--color-gold-light); }

  @media (max-width: 768px) {
    .mobile-cta-bar { display: flex; }
  }
</style>
