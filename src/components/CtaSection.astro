---
// CtaSection — Reusable dark CTA block
// Source: DESIGN.md §12 CTA architecture, CONTENT/homepage.md §7
// Decorative: grain texture + topographic gold lines (BUILD-PLAN.md)
// Centered — the ONLY centered section per anti-patterns
interface Props {
  overline?: string;
  heading: string;
  body: string;
  buttonText?: string;
  buttonHref?: string;
  microcopy?: string;
}
const {
  overline = 'GET IN TOUCH',
  heading,
  body,
  buttonText = 'Begin a Conversation',
  buttonHref = '/contact/',
  microcopy = 'No obligation \u00B7 Personal response within 24 hours',
} = Astro.props;

const endsWithQuestion = heading.endsWith('?');
const displayHeading = endsWithQuestion ? heading.slice(0, -1) : heading;
---

<section class="cta-section">
  <!-- Grain texture (BUILD-PLAN.md craft element #1 — feTurbulence) -->
  <svg class="grain" aria-hidden="true">
    <filter id="g-cta">
      <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="4" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#g-cta)"/>
  </svg>

  <!-- Topographic gold lines (BUILD-PLAN.md craft element #4 — 4% opacity) -->
  <svg
    aria-hidden="true"
    class="topo-lines"
    viewBox="0 0 1440 400"
    fill="none"
    preserveAspectRatio="none"
  >
    <path d="M0,160 C320,220 640,100 960,180 C1120,220 1280,140 1440,200" stroke="var(--color-gold)" stroke-width="1.5" fill="none"/>
    <path d="M0,200 C360,130 720,270 1080,170 C1260,130 1360,210 1440,180" stroke="var(--color-gold)" stroke-width="1.5" fill="none" opacity="0.6"/>
    <path d="M0,240 C280,300 560,180 840,260 C1120,340 1300,220 1440,260" stroke="var(--color-gold)" stroke-width="1.5" fill="none" opacity="0.35"/>
  </svg>

  <div class="cta-inner reveal">
    <span class="overline">{overline}</span>
    {endsWithQuestion
      ? <h2 class="cta-h2">{displayHeading}<span class="gold-mark">?</span></h2>
      : <h2 class="cta-h2 gold-dot">{displayHeading}</h2>
    }
    <p class="cta-body">{body}</p>
    <div class="cta-group">
      <a href={buttonHref} class="btn btn-gold">{buttonText}</a>
      {microcopy && <p class="microcopy">{microcopy}</p>}
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--color-dark);
    padding-block: clamp(6rem, 7vw + 2rem, 10rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.27;
  }
  .topo-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.04;
  }
  .cta-inner {
    position: relative;
    z-index: 2;
    padding-inline: clamp(1.5rem, 5vw, 5rem);
    max-width: 42.5rem;
    margin-inline: auto;
  }
  .overline {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-text-muted-dark);
    display: block;
    margin-bottom: 0.875rem;
  }
  .cta-h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 2rem + 3vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-on-dark);
    margin-bottom: 1.25rem;
  }
  .gold-dot::after { content: '.'; color: var(--color-gold); }
  .gold-mark { color: var(--color-gold); }
  .cta-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.68;
    color: var(--color-text-muted-dark);
    margin-bottom: 2.5rem;
    max-width: 42ch;
    margin-inline: auto;
  }
  .cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  /* .btn and .microcopy are global — see global.css */
  .btn { display: inline-block; text-decoration: none; }
</style>
