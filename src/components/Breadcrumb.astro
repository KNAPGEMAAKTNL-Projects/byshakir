---
// Breadcrumb — Home > [Section] > [Page]
// variant="dark"  → light text, for use inside dark hero sections (default)
// variant="light" → dark text, for use on light surface backgrounds
interface BreadcrumbItem {
  label: string;
  href?: string;
}
interface Props {
  items: BreadcrumbItem[];
  variant?: 'dark' | 'light';
}
const { items, variant = 'dark' } = Astro.props;
---

{items.length > 0 && (
  <nav class={`breadcrumb breadcrumb--${variant}`} aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      {items.map((item, i) => (
        <li>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          {item.href && i < items.length - 1
            ? <a href={item.href}>{item.label}</a>
            : <span aria-current="page">{item.label}</span>
          }
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .breadcrumb {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    margin-top: 0.75rem;
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .breadcrumb li { display: flex; align-items: center; }
  .breadcrumb a {
    text-decoration: none;
    transition: color 0.3s;
  }
  .breadcrumb a:hover { color: var(--color-gold); }
  .breadcrumb-sep {
    margin-inline: 0.5rem;
    opacity: 0.4;
  }

  /* Dark variant — breadcrumb inside dark hero */
  .breadcrumb--dark { color: var(--color-text-muted-dark); }
  .breadcrumb--dark a { color: var(--color-text-muted-dark); }
  .breadcrumb--dark [aria-current="page"] {
    color: var(--color-text-on-dark);
    opacity: 0.8;
  }

  /* Light variant — breadcrumb on light surface (e.g. breadcrumb-bar) */
  .breadcrumb--light { color: var(--color-text-muted); }
  .breadcrumb--light a { color: var(--color-text-muted); }
  .breadcrumb--light [aria-current="page"] {
    color: var(--color-text);
    opacity: 0.8;
  }
</style>
