---
// Footer — 2-column asymmetric (1fr auto)
// Source: DESIGN.md §16 legal requirements, CONTENT/homepage.md §8
// Background: #1E150D (darker than dark sections)
const year = new Date().getFullYear();

const navLinks = [
  { label: 'Projects', href: '/projects/' },
  { label: 'Services', href: '/services/' },
  { label: 'About', href: '/about/' },
  { label: 'FAQ', href: '/faq/' },
  { label: 'Contact', href: '/contact/' },
];

const legalLinks = [
  { label: 'Privacy', href: '/privacy/' },
  { label: 'Cookies', href: '/cookie-statement/' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Left column — brand, address, legal -->
    <div>
      <a href="/" class="footer-brand">By Shakir</a>
      <span class="footer-tagline" aria-hidden="true">Luxury Interior Design</span>
      <address class="footer-address">
        Gijsbert Stoutweg 8<br/>
        4005 LE Tiel<br/>
        The Netherlands
      </address>
      <div class="footer-contact">
        <a href="tel:+31344655473">+31 344 655 473</a>
        <a href="mailto:info@byshakir.com">info@byshakir.com</a>
      </div>
      <div class="footer-legal">
        <span>KvK: 11060878</span>
        <span class="footer-legal-sep">&middot;</span>
        {legalLinks.map(({ label, href }) => (
          <a href={href}>{label}</a>
        ))}
        <span class="footer-legal-sep">&middot;</span>
        <span>&copy; {year} By Shakir</span>
      </div>
    </div>

    <!-- Right column — nav + WhatsApp -->
    <div class="footer-right">
      <nav class="footer-nav" aria-label="Footer navigation">
        {navLinks.map(({ label, href }) => (
          <a href={href}>{label}</a>
        ))}
      </nav>
      <!-- WhatsApp — link-cta style, no icon (DESIGN.md §12) -->
      <a
        href="https://wa.me/31344655473?text=Hello%2C%20I%20would%20like%20to%20discuss%20a%20project."
        class="footer-whatsapp link-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Message Us on WhatsApp
        <!-- Arrow right — inline SVG (DESIGN.md §8) -->
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-left:6px;">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark-alt);
    border-top: 1px solid var(--color-gold-border);
    padding-block: clamp(3rem, 3.5vw + 1rem, 5rem);
  }
  .footer-inner {
    padding-inline: clamp(1.5rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 5vw, 7rem);
    align-items: start;
  }
  .footer-brand {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-decoration: none;
    display: block;
    margin-bottom: 0.4rem;
  }
  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.625rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-muted-dark);
    opacity: 0.5;
    display: block;
    margin-bottom: 1.5rem;
  }
  .footer-address {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-muted-dark);
    font-style: normal;
    margin-bottom: 1rem;
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }
  .footer-contact a {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 300;
    color: var(--color-text-muted-dark);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-contact a:hover { color: var(--color-text-on-dark); }
  .footer-legal {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--color-text-muted-dark) 35%, transparent);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .footer-legal a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text-muted-dark) 15%, transparent);
    transition: color 0.3s;
  }
  .footer-legal a:hover { color: var(--color-text-muted-dark); }
  .footer-legal-sep { opacity: 0.5; }

  .footer-right { text-align: right; }
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, auto);
    column-gap: 2.25rem;
    row-gap: 0.625rem;
    margin-bottom: 2rem;
    justify-content: end;
  }
  .footer-nav a {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted-dark);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-nav a:hover { color: var(--color-text-on-dark); }

  .footer-whatsapp {
    color: var(--color-text-on-dark);
  }
  .link-cta {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-gold);
    display: inline-block;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .link-cta:hover { opacity: 0.65; }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .footer-right { text-align: left; }
    .footer-nav {
      justify-content: start;
      column-gap: 2.5rem;
    }
  }
</style>
